# NextAuth / Auth.js — påkrævet i produktion
AUTH_SECRET=generer-en-lang-tilfældig-streng
AUTH_URL=http://localhost:3000

# Eneste admin-bruger (simpel login)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=skift-denne-adgangskode

# Vises i navigation, footer og sidetitler
ARTIST_NAME=Dit Navn Her

# Kontakt (valgfri — standard er ingrid@example.com i koden hvis tom)
CONTACT_EMAIL=ingrid@example.com
RESEND_API_KEY=
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# Test-mode: med sk_test_ key kan checkout køre uden connected account.
# Sæt til false for at tvinge connected account også i test.
STRIPE_TEST_MODE_ALLOW_DIRECT=true
SHIPMONDO_API_USER=...
SHIPMONDO_API_KEY=...

# Facebook/Instagram: redigeres i admin under «Kontakt» (Supabase-tabellen contact_settings, id = main)

# Supabase (påkrævet i produktion/serverless for uploads + maleri- og begivenhedsdata)
# Brug URL i format: https://<project-ref>.supabase.co
# Tabeller: kør sql/supabase-*-setup.sql — paintings (manuel), jewelry, events, about_content
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ANTHROPIC_API_KEY=sk-ant-...
NEXT_PUBLIC_SITE_URL=https://ingrid-borten.vercel.app
